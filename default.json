{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits",
    ":timezone(Asia/Tokyo)",
    "schedule:weekly"
  ],
  "minimumReleaseAge": "3 days",
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": [
    "dependencies"
  ],
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 9am on the first day of the month"
    ],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability"
    ]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch + pin + digest updates",
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Auto-merge non-major devDependencies",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Auto-merge minor updates for type/lint tooling",
      "matchUpdateTypes": [
        "minor"
      ],
      "matchPackageNames": [
        "@types/*",
        "eslint",
        "@typescript-eslint/*"
      ],
      "automerge": true
    },
    {
      "description": "Never auto-merge Next.js framework (manual review)",
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "eslint-config-next"
      ],
      "groupName": "Next.js framework",
      "automerge": false,
      "labels": [
        "dependencies",
        "framework-major"
      ]
    },
    {
      "description": "Never auto-merge Stripe (payment-critical)",
      "matchPackageNames": [
        "stripe",
        "@stripe/stripe-js"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "stripe-critical"
      ]
    },
    {
      "description": "Never auto-merge Supabase (data-critical)",
      "matchPackageNames": [
        "@supabase/supabase-js",
        "@supabase/ssr"
      ],
      "groupName": "Supabase",
      "automerge": false,
      "labels": [
        "dependencies",
        "supabase-critical"
      ]
    },
    {
      "description": "Group all GitHub Actions updates into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "automerge": true
    }
  ]
}
